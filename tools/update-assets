#!/usr/bin/env -S java --source 25

import java.io.IOException;
import java.awt.RenderingHints;
import java.awt.image.BufferedImage;
import java.nio.charset.StandardCharsets;
import java.nio.file.StandardCopyOption;
import java.nio.file.Files;
import java.nio.file.Path;
import java.util.ArrayList;
import java.util.Comparator;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.stream.Stream;

import javax.imageio.ImageIO;

class UpdateAssetsScript {

    private static final String HEADER = "Noun,Article,Image,Audio,AnswerAudio";
    private static final List<String> VALID_ARTICLES = List.of("der", "die", "das");

    private record Row(String noun, String article, String imagePath, String audioPath, String answerAudioPath) {
    }

    public static void main(final String[] args) throws Exception {
        final Path root = resolveRootDirectory();
        final Path originalsDir = root.resolve("assets/images/original");
        final Path newImagesDir = root.resolve("assets/images/new");
        final Path resizedImagesDir = root.resolve("assets/images/420");
        final Path csvPath = root.resolve("assets/articles.csv");
        final Path ttsScript = root.resolve("tools/tts");

        requireOrCreateDirectory(originalsDir);
        requireOrCreateDirectory(newImagesDir);
        requireOrCreateDirectory(resizedImagesDir);
        requireFile(csvPath);
        requireExecutable(ttsScript);

        final Map<String, Row> rowsByImage = loadArticlesCsv(csvPath);
        final Map<String, Path> sourceImages = listSourceImages(originalsDir, newImagesDir);
        final List<String> imageNames = sourceImages.keySet().stream().sorted(Comparator.naturalOrder()).toList();

        final List<String> missingMetadata = new ArrayList<>();
        final List<Row> orderedRows = new ArrayList<>();

        for (String imageName : imageNames) {
            requireAsciiImageName(imageName);

            final String stem = imageName.substring(0, imageName.length() - ".png".length());
            final Row existing = rowsByImage.get(imageName);

            final String noun = existing != null ? existing.noun : null;
            final String article = existing != null ? existing.article : null;
            if (noun == null || article == null) {
                missingMetadata.add(imageName);
                continue;
            }
            validateArticle(article, imageName);

            final String imagePath = existing != null ? existing.imagePath : "assets/images/420/" + imageName;
            final String defaultStemAudioPath = "assets/audio/" + stem + ".mp3";
            final String defaultStemAnswerAudioPath = "assets/audio/" + article + " " + stem + ".mp3";
            final String nounAudioPath = "assets/audio/" + noun + ".mp3";
            final String nounAnswerAudioPath = "assets/audio/" + article + " " + noun + ".mp3";
            final boolean nounIsAsciiSafe = isAscii(noun);

            final String audioPath = existing != null
                    ? !isAscii(existing.audioPath)
                        ? defaultStemAudioPath
                        : nounIsAsciiSafe && existing.audioPath.equals(defaultStemAudioPath) ? nounAudioPath : existing.audioPath
                    : nounAudioPath;

            final String answerAudioPath = existing != null
                    ? !isAscii(existing.answerAudioPath)
                        ? defaultStemAnswerAudioPath
                        : nounIsAsciiSafe && existing.answerAudioPath.equals(defaultStemAnswerAudioPath) ? nounAnswerAudioPath : existing.answerAudioPath
                    : nounAnswerAudioPath;

            orderedRows.add(new Row(noun, article, imagePath, audioPath, answerAudioPath));
        }

        if (!missingMetadata.isEmpty()) {
            System.err.println("Missing metadata for new images. Add these rows to assets/articles.csv:");
            for (String imageName : missingMetadata) {
                final String stem = imageName.substring(0, imageName.length() - ".png".length());
                System.err.println(stem + ",<der|die|das>,assets/images/420/" + imageName + ",assets/audio/" + stem + ".mp3,assets/audio/<der|die|das> " + stem + ".mp3");
            }
            System.exit(1);
        }

        generateMissingResizedImages(sourceImages, resizedImagesDir, imageNames);
        writeArticlesCsv(csvPath, orderedRows);
        generateMissingAudio(root, ttsScript, orderedRows);
        moveNewImagesToOriginal(newImagesDir, originalsDir);

        System.out.println("Updated " + csvPath + " and generated missing audio files.");
    }

    private static Path resolveRootDirectory() {
        final String source = System.getProperty("jdk.launcher.sourcefile");
        if (source == null) {
            return Path.of(".").toAbsolutePath().normalize();
        }
        return Path.of(source).toAbsolutePath().normalize().getParent().getParent();
    }

    private static void requireOrCreateDirectory(final Path path) {
        try {
            Files.createDirectories(path);
        } catch (IOException e) {
            throw new IllegalStateException("Failed to create directory: " + path, e);
        }
    }

    private static void requireFile(final Path path) {
        if (!Files.isRegularFile(path)) {
            System.err.println("Missing file: " + path);
            System.exit(1);
        }
    }

    private static void requireExecutable(final Path path) {
        if (!Files.isExecutable(path)) {
            System.err.println("Missing executable script: " + path);
            System.exit(1);
        }
    }

    private static Map<String, Row> loadArticlesCsv(final Path csvPath) throws IOException {
        final Map<String, Row> rows = new HashMap<>();
        final List<String> lines = Files.readAllLines(csvPath, StandardCharsets.UTF_8);
        for (int i = 1; i < lines.size(); i++) {
            final String line = lines.get(i).trim();
            if (line.isEmpty()) {
                continue;
            }
            final String[] parts = line.split(",", -1);
            if (parts.length < 5) {
                throw new IllegalStateException("Invalid CSV row in " + csvPath + ": " + line);
            }

            final String noun = parts[0].trim();
            final String article = parts[1].trim();
            final String imagePath = parts[2].trim();
            final String audioPath = parts[3].trim();
            final String answerAudioPath = parts[4].trim();
            final String imageName = Path.of(imagePath).getFileName().toString();

            rows.put(imageName, new Row(noun, article, imagePath, audioPath, answerAudioPath));
        }
        return rows;
    }

    private static Map<String, Path> listSourceImages(final Path originalsDir, final Path newImagesDir) throws IOException {
        final Map<String, Path> sourceImages = new HashMap<>();
        addImagesFromDirectory(sourceImages, originalsDir);
        addImagesFromDirectory(sourceImages, newImagesDir);
        return sourceImages;
    }

    private static void addImagesFromDirectory(final Map<String, Path> sourceImages, final Path directory) throws IOException {
        try (Stream<Path> files = Files.list(directory)) {
            for (Path file : files.filter(Files::isRegularFile).toList()) {
                final String imageName = file.getFileName().toString();
                if (!imageName.endsWith(".png")) {
                    continue;
                }
                if (sourceImages.containsKey(imageName)) {
                    throw new IllegalStateException("Duplicate source image name across source folders: " + imageName);
                }
                sourceImages.put(imageName, file);
            }
        }
    }

    private static void requireAsciiImageName(final String imageName) {
        for (int i = 0; i < imageName.length(); i++) {
            if (imageName.charAt(i) > 127) {
                System.err.println("Image filename '" + imageName + "' is not ASCII. Rename to ASCII-safe filename first.");
                System.exit(1);
            }
        }
    }

    private static void validateArticle(final String article, final String imageName) {
        if (!VALID_ARTICLES.contains(article)) {
            throw new IllegalStateException("Invalid article '" + article + "' for image '" + imageName + "'");
        }
    }

    private static boolean isAscii(final String value) {
        for (int i = 0; i < value.length(); i++) {
            if (value.charAt(i) > 127) {
                return false;
            }
        }
        return true;
    }

    private static void writeArticlesCsv(final Path csvPath, final List<Row> rows) throws IOException {
        final List<String> lines = new ArrayList<>();
        lines.add(HEADER);
        for (Row row : rows) {
            lines.add(String.join(",", row.noun, row.article, row.imagePath, row.audioPath, row.answerAudioPath));
        }
        Files.write(csvPath, lines, StandardCharsets.UTF_8);
    }

    private static void generateMissingResizedImages(final Map<String, Path> sourceImages, final Path resizedDir, final List<String> imageNames) throws IOException {
        for (String imageName : imageNames) {
            final Path outputPath = resizedDir.resolve(imageName);
            if (Files.exists(outputPath)) {
                continue;
            }

            final Path inputPath = sourceImages.get(imageName);
            final BufferedImage original = ImageIO.read(inputPath.toFile());
            if (original == null) {
                throw new IllegalStateException("Unable to decode image: " + inputPath);
            }

            final int targetHeight = 420;
            final int targetWidth = Math.max(1, (int) Math.round((double) original.getWidth() * targetHeight / original.getHeight()));
            final BufferedImage resized = new BufferedImage(targetWidth, targetHeight, BufferedImage.TYPE_INT_ARGB);
            final var graphics = resized.createGraphics();
            try {
                graphics.setRenderingHint(RenderingHints.KEY_INTERPOLATION, RenderingHints.VALUE_INTERPOLATION_BICUBIC);
                graphics.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY);
                graphics.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                graphics.drawImage(original, 0, 0, targetWidth, targetHeight, null);
            } finally {
                graphics.dispose();
            }

            final boolean written = ImageIO.write(resized, "png", outputPath.toFile());
            if (!written) {
                throw new IllegalStateException("Unable to write PNG image: " + outputPath);
            }
        }
    }

    private static void moveNewImagesToOriginal(final Path newImagesDir, final Path originalsDir) throws IOException {
        try (Stream<Path> files = Files.list(newImagesDir)) {
            for (Path file : files.filter(Files::isRegularFile).toList()) {
                final String imageName = file.getFileName().toString();
                if (!imageName.endsWith(".png")) {
                    continue;
                }
                final Path destination = originalsDir.resolve(imageName);
                if (Files.exists(destination)) {
                    throw new IllegalStateException("Cannot move image from assets/images/new because it already exists in assets/images/original: " + imageName);
                }
                Files.move(file, destination, StandardCopyOption.ATOMIC_MOVE);
            }
        }
    }

    private static void generateMissingAudio(final Path root, final Path ttsScript, final List<Row> rows) throws Exception {
        for (Row row : rows) {
            final Path nounAudio = root.resolve(row.audioPath);
            final Path answerAudio = root.resolve(row.answerAudioPath);

            if (!Files.exists(nounAudio)) {
                runTts(ttsScript, row.noun, nounAudio);
            }
            if (!Files.exists(answerAudio)) {
                runTts(ttsScript, row.article + " " + row.noun, answerAudio);
            }
        }
    }

    private static void runTts(final Path ttsScript, final String text, final Path output) throws Exception {
        final Process process = new ProcessBuilder(ttsScript.toString(), text, output.toString())
                .inheritIO()
                .start();
        final int exitCode = process.waitFor();
        if (exitCode != 0) {
            throw new IllegalStateException("TTS command failed for output: " + output);
        }
    }
}
