#!/usr/bin/env -S java --source 25

import java.awt.RenderingHints;
import java.awt.image.BufferedImage;
import java.io.IOException;
import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.StandardCopyOption;
import java.util.ArrayList;
import java.util.Comparator;
import java.util.HashMap;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.regex.Pattern;
import java.util.stream.Stream;

import javax.imageio.ImageIO;

class UpdateAssetsScript {

    private static final String HEADER = "Id,Noun,Article,Category,Image,Audio,AnswerAudio";
    private static final List<String> VALID_ARTICLES = List.of("der", "die", "das");
    private static final Pattern ASCII_SLUG = Pattern.compile("[a-z0-9]+(?:-[a-z0-9]+)*");

    private record Row(String id,
                       String noun,
                       String article,
                       String category,
                       String imageFileName,
                       String audioPath,
                       String answerAudioPath) {

        String imagePath() {
            return "assets/images/420/" + category + "/" + imageFileName;
        }
    }

    public static void main(final String[] args) throws Exception {
        final Path root = resolveRootDirectory();
        final Path originalsDir = root.resolve("assets/images/original");
        final Path newImagesDir = root.resolve("assets/images/new");
        final Path resizedImagesDir = root.resolve("assets/images/420");
        final Path csvPath = root.resolve("assets/articles.csv");
        final Path ttsScript = root.resolve("tools/tts");

        requireOrCreateDirectory(originalsDir);
        requireOrCreateDirectory(newImagesDir);
        requireOrCreateDirectory(resizedImagesDir);
        requireFile(csvPath);
        requireExecutable(ttsScript);

        final Map<String, Row> rowsByImage = loadArticlesCsv(csvPath);
        final Map<String, Path> sourceImages = listSourceImages(originalsDir, newImagesDir);

        final List<String> missingMetadata = new ArrayList<>();
        final List<String> missingSourceImages = new ArrayList<>();
        final List<Row> orderedRows = new ArrayList<>();

        for (String imageName : sourceImages.keySet().stream().sorted(Comparator.naturalOrder()).toList()) {
            requireAsciiImageName(imageName);

            final Row existing = rowsByImage.get(imageName);
            if (existing == null) {
                missingMetadata.add(imageName);
                continue;
            }

            validateRow(existing, imageName);

            final String stem = imageName.substring(0, imageName.length() - ".png".length());
            final String defaultStemAudioPath = "assets/audio/" + stem + ".mp3";
            final String defaultStemAnswerAudioPath = "assets/audio/" + existing.article + " " + stem + ".mp3";
            final String nounAudioPath = "assets/audio/" + existing.noun + ".mp3";
            final String nounAnswerAudioPath = "assets/audio/" + existing.article + " " + existing.noun + ".mp3";
            final boolean nounIsAsciiSafe = isAscii(existing.noun);

            final String audioPath = !isAscii(existing.audioPath)
                    ? defaultStemAudioPath
                    : nounIsAsciiSafe && existing.audioPath.equals(defaultStemAudioPath) ? nounAudioPath : existing.audioPath;

            final String answerAudioPath = !isAscii(existing.answerAudioPath)
                    ? defaultStemAnswerAudioPath
                    : nounIsAsciiSafe && existing.answerAudioPath.equals(defaultStemAnswerAudioPath)
                        ? nounAnswerAudioPath
                        : existing.answerAudioPath;

            orderedRows.add(new Row(
                    existing.id,
                    existing.noun,
                    existing.article,
                    existing.category,
                    imageName,
                    audioPath,
                    answerAudioPath));
        }

        for (String imageName : rowsByImage.keySet().stream().sorted(Comparator.naturalOrder()).toList()) {
            if (!sourceImages.containsKey(imageName)) {
                missingSourceImages.add(imageName);
            }
        }

        if (!missingSourceImages.isEmpty()) {
            throw new IllegalStateException("CSV rows point to missing source images: " + String.join(", ", missingSourceImages));
        }

        if (!missingMetadata.isEmpty()) {
            System.err.println("Missing metadata for new images. Add these rows to assets/articles.csv:");
            for (String imageName : missingMetadata) {
                final String stem = imageName.substring(0, imageName.length() - ".png".length());
                final String id = deriveDefaultId(stem);
                System.err.println(
                        id
                                + ","
                                + stem
                                + ",<der|die|das>,<category>,assets/images/420/<category>/"
                                + imageName
                                + ",assets/audio/"
                                + stem
                                + ".mp3,assets/audio/<der|die|das> "
                                + stem
                                + ".mp3");
            }
            System.exit(1);
        }

        orderedRows.sort(Comparator.comparing(Row::id));

        generateMissingResizedImages(sourceImages, resizedImagesDir, orderedRows);
        writeArticlesCsv(csvPath, orderedRows);
        generateMissingAudio(root, ttsScript, orderedRows);
        moveNewImagesToOriginal(newImagesDir, originalsDir, sourceImages, orderedRows);

        System.out.println("Updated " + csvPath + " and generated missing audio files.");
    }

    private static Path resolveRootDirectory() {
        final String source = System.getProperty("jdk.launcher.sourcefile");
        if (source == null) {
            return Path.of(".").toAbsolutePath().normalize();
        }
        return Path.of(source).toAbsolutePath().normalize().getParent().getParent();
    }

    private static void requireOrCreateDirectory(final Path path) {
        try {
            Files.createDirectories(path);
        } catch (IOException e) {
            throw new IllegalStateException("Failed to create directory: " + path, e);
        }
    }

    private static void requireFile(final Path path) {
        if (!Files.isRegularFile(path)) {
            System.err.println("Missing file: " + path);
            System.exit(1);
        }
    }

    private static void requireExecutable(final Path path) {
        if (!Files.isExecutable(path)) {
            System.err.println("Missing executable script: " + path);
            System.exit(1);
        }
    }

    private static Map<String, Row> loadArticlesCsv(final Path csvPath) throws IOException {
        final List<String> lines = Files.readAllLines(csvPath, StandardCharsets.UTF_8);
        if (lines.isEmpty()) {
            throw new IllegalStateException("CSV file is empty: " + csvPath);
        }

        final HeaderColumns header = parseHeader(lines.getFirst());
        final Map<String, Row> rows = new LinkedHashMap<>();

        for (int i = 1; i < lines.size(); i++) {
            final String line = lines.get(i).trim();
            if (line.isEmpty()) {
                continue;
            }

            final String[] parts = line.split(",", -1);
            final String id = get(parts, header.idIndex).trim();
            final String noun = get(parts, header.nounIndex).trim();
            final String article = get(parts, header.articleIndex).trim();
            final String category = get(parts, header.categoryIndex).trim();
            final String imagePath = get(parts, header.imageIndex).trim();
            final String audioPath = get(parts, header.audioIndex).trim();
            final String answerAudioPath = get(parts, header.answerAudioIndex).trim();
            final String imageName = Path.of(imagePath).getFileName().toString();

            if (rows.put(imageName, new Row(id, noun, article, category, imageName, audioPath, answerAudioPath)) != null) {
                throw new IllegalStateException("Duplicate CSV image entry for " + imageName + " in " + csvPath);
            }
        }

        return rows;
    }

    private static HeaderColumns parseHeader(final String line) {
        final String[] parts = line.split(",", -1);
        final Map<String, Integer> index = new HashMap<>();
        for (int i = 0; i < parts.length; i++) {
            index.put(parts[i].trim(), i);
        }

        return new HeaderColumns(
                requiredColumn(index, "Id"),
                requiredColumn(index, "Noun"),
                requiredColumn(index, "Article"),
                requiredColumn(index, "Category"),
                requiredColumn(index, "Image"),
                requiredColumn(index, "Audio"),
                requiredColumn(index, "AnswerAudio"));
    }

    private static int requiredColumn(final Map<String, Integer> columns, final String name) {
        final Integer index = columns.get(name);
        if (index == null) {
            throw new IllegalStateException("CSV header is missing required column: " + name);
        }
        return index;
    }

    private static String get(final String[] parts, final int index) {
        if (index < 0 || index >= parts.length) {
            return "";
        }
        return parts[index];
    }

    private static Map<String, Path> listSourceImages(final Path originalsDir, final Path newImagesDir) throws IOException {
        final Map<String, Path> sourceImages = new HashMap<>();
        addImagesFromDirectory(sourceImages, originalsDir);
        addImagesFromDirectory(sourceImages, newImagesDir);
        return sourceImages;
    }

    private static void addImagesFromDirectory(final Map<String, Path> sourceImages, final Path directory) throws IOException {
        if (!Files.exists(directory)) {
            return;
        }
        try (Stream<Path> files = Files.walk(directory)) {
            for (Path file : files.filter(Files::isRegularFile).toList()) {
                final String imageName = file.getFileName().toString();
                if (!imageName.endsWith(".png")) {
                    continue;
                }
                if (sourceImages.containsKey(imageName)) {
                    throw new IllegalStateException("Duplicate source image filename across asset folders: " + imageName);
                }
                sourceImages.put(imageName, file);
            }
        }
    }

    private static void validateRow(final Row row, final String imageName) {
        validateSlug("id", row.id, imageName);
        validateSlug("category", row.category, imageName);
        validateArticle(row.article, imageName);
        requireAsciiImageName(imageName);
        if (row.noun.isBlank()) {
            throw new IllegalStateException("Missing noun for image '" + imageName + "'");
        }
        if (row.audioPath.isBlank() || row.answerAudioPath.isBlank()) {
            throw new IllegalStateException("Missing audio path metadata for image '" + imageName + "'");
        }
    }

    private static void validateSlug(final String fieldName, final String value, final String imageName) {
        if (!ASCII_SLUG.matcher(value).matches()) {
            throw new IllegalStateException("Invalid " + fieldName + " '" + value + "' for image '" + imageName + "'");
        }
    }

    private static void requireAsciiImageName(final String imageName) {
        for (int i = 0; i < imageName.length(); i++) {
            if (imageName.charAt(i) > 127) {
                System.err.println("Image filename '" + imageName + "' is not ASCII. Rename to ASCII-safe filename first.");
                System.exit(1);
            }
        }
    }

    private static void validateArticle(final String article, final String imageName) {
        if (!VALID_ARTICLES.contains(article)) {
            throw new IllegalStateException("Invalid article '" + article + "' for image '" + imageName + "'");
        }
    }

    private static boolean isAscii(final String value) {
        for (int i = 0; i < value.length(); i++) {
            if (value.charAt(i) > 127) {
                return false;
            }
        }
        return true;
    }

    private static String deriveDefaultId(final String stem) {
        return stem.toLowerCase();
    }

    private static void writeArticlesCsv(final Path csvPath, final List<Row> rows) throws IOException {
        final List<String> lines = new ArrayList<>();
        lines.add(HEADER);
        for (Row row : rows) {
            lines.add(String.join(",",
                    row.id,
                    row.noun,
                    row.article,
                    row.category,
                    row.imagePath(),
                    row.audioPath,
                    row.answerAudioPath));
        }
        Files.write(csvPath, lines, StandardCharsets.UTF_8);
    }

    private static void generateMissingResizedImages(final Map<String, Path> sourceImages,
                                                     final Path resizedDir,
                                                     final List<Row> rows) throws IOException {
        for (Row row : rows) {
            final Path outputPath = resizedDir.resolve(row.category).resolve(row.imageFileName);
            if (Files.exists(outputPath)) {
                continue;
            }

            Files.createDirectories(outputPath.getParent());

            final Path inputPath = sourceImages.get(row.imageFileName);
            final BufferedImage original = ImageIO.read(inputPath.toFile());
            if (original == null) {
                throw new IllegalStateException("Unable to decode image: " + inputPath);
            }

            final int targetHeight = 420;
            final int targetWidth = Math.max(1, (int) Math.round((double) original.getWidth() * targetHeight / original.getHeight()));
            final BufferedImage resized = new BufferedImage(targetWidth, targetHeight, BufferedImage.TYPE_INT_ARGB);
            final var graphics = resized.createGraphics();
            try {
                graphics.setRenderingHint(RenderingHints.KEY_INTERPOLATION, RenderingHints.VALUE_INTERPOLATION_BICUBIC);
                graphics.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY);
                graphics.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                graphics.drawImage(original, 0, 0, targetWidth, targetHeight, null);
            } finally {
                graphics.dispose();
            }

            final boolean written = ImageIO.write(resized, "png", outputPath.toFile());
            if (!written) {
                throw new IllegalStateException("Unable to write PNG image: " + outputPath);
            }
        }
    }

    private static void moveNewImagesToOriginal(final Path newImagesDir,
                                                final Path originalsDir,
                                                final Map<String, Path> sourceImages,
                                                final List<Row> rows) throws IOException {
        for (Row row : rows) {
            final Path sourcePath = sourceImages.get(row.imageFileName);
            if (sourcePath == null || !sourcePath.startsWith(newImagesDir)) {
                continue;
            }

            final Path destination = originalsDir.resolve(row.category).resolve(row.imageFileName);
            Files.createDirectories(destination.getParent());
            if (Files.exists(destination)) {
                throw new IllegalStateException(
                        "Cannot move image from assets/images/new because it already exists in assets/images/original: " + destination);
            }
            Files.move(sourcePath, destination, StandardCopyOption.ATOMIC_MOVE);
        }
    }

    private static void generateMissingAudio(final Path root, final Path ttsScript, final List<Row> rows) throws Exception {
        for (Row row : rows) {
            final Path nounAudio = root.resolve(row.audioPath);
            final Path answerAudio = root.resolve(row.answerAudioPath);

            if (!Files.exists(nounAudio)) {
                runTts(ttsScript, row.noun, nounAudio);
            }
            if (!Files.exists(answerAudio)) {
                runTts(ttsScript, row.article + " " + row.noun, answerAudio);
            }
        }
    }

    private static void runTts(final Path ttsScript, final String text, final Path output) throws Exception {
        Files.createDirectories(output.getParent());
        final Process process = new ProcessBuilder(ttsScript.toString(), text, output.toString())
                .inheritIO()
                .start();
        final int exitCode = process.waitFor();
        if (exitCode != 0) {
            throw new IllegalStateException("TTS command failed for output: " + output);
        }
    }

    private record HeaderColumns(int idIndex,
                                 int nounIndex,
                                 int articleIndex,
                                 int categoryIndex,
                                 int imageIndex,
                                 int audioIndex,
                                 int answerAudioIndex) {
    }
}
