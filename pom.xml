<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.5</version>
        <relativePath/>
    </parent>

    <groupId>com.wortwerk</groupId>
    <artifactId>wort-werk</artifactId>
    <version>0.0.1</version>
    <name>Wort Werk</name>
    <description>German article trainer with Spring Boot, Thymeleaf, and HTMX</description>

    <properties>
        <java.version>25</java.version>
        <required.maven.version>3.6.3</required.maven.version>
        <oci.java.sdk.version>3.81.1</oci.java.sdk.version>
        <playwright.version>1.58.0</playwright.version>
        <maven.build.timestamp.format>yyyyMMddHHmmss</maven.build.timestamp.format>
        <verify.container.port>18080</verify.container.port>
        <verify.container.image>${project.artifactId}:verify-${maven.build.timestamp}</verify.container.image>
        <verify.container.base-url>http://localhost:${verify.container.port}</verify.container.base-url>
        <verify.environment.backend>compose</verify.environment.backend>
        <verify.environment.script>${project.basedir}/tools/verify-environment.sh</verify.environment.script>
        <verify.compose.file>${project.basedir}/container/compose.verify.yml</verify.compose.file>
        <verify.compose.project>${project.artifactId}-verify</verify.compose.project>
        <verify.db.port>15432</verify.db.port>
        <verify.db.name>wortwerk_verify</verify.db.name>
        <verify.db.host.port.url>jdbc:postgresql://localhost:${verify.db.port}/${verify.db.name}</verify.db.host.port.url>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.oracle.oci.sdk</groupId>
                <artifactId>oci-java-sdk-bom</artifactId>
                <version>${oci.java.sdk.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- Web -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-thymeleaf</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- Auth -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-webauthn</artifactId>
        </dependency>

        <!-- Data -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-jdbc</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-flyway</artifactId>
        </dependency>
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-database-postgresql</artifactId>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>com.oracle.oci.sdk</groupId>
            <artifactId>oci-java-sdk-secrets</artifactId>
        </dependency>
        <dependency>
            <groupId>com.oracle.oci.sdk</groupId>
            <artifactId>oci-java-sdk-common-httpclient-jersey3</artifactId>
        </dependency>

        <!-- Testing -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-webmvc-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.microsoft.playwright</groupId>
            <artifactId>playwright</artifactId>
            <version>${playwright.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>-XX:+EnableDynamicAgentLoading</argLine>
                    <excludedGroups>e2e | db</excludedGroups>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <configuration>
                    <argLine>-XX:+EnableDynamicAgentLoading</argLine>
                    <groups>e2e | db</groups>
                    <includes>
                        <include>**/*Test.java</include>
                    </includes>
                    <systemPropertyVariables>
                        <test.base-url>${verify.container.base-url}</test.base-url>
                        <spring.datasource.url>${verify.db.host.port.url}</spring.datasource.url>
                        <spring.datasource.username>${env.VERIFY_DB_USERNAME}</spring.datasource.username>
                        <spring.datasource.password>${env.VERIFY_DB_PASSWORD}</spring.datasource.password>
                    </systemPropertyVariables>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <id>verify-require-db-credentials</id>
                        <phase>pre-integration-test</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>sh</executable>
                            <arguments>
                                <argument>-c</argument>
                                <argument>test -n "${VERIFY_DB_USERNAME:-}" &amp;&amp; test -n "${VERIFY_DB_PASSWORD:-}" || { echo "Missing required environment variables: VERIFY_DB_USERNAME and VERIFY_DB_PASSWORD"; exit 1; }</argument>
                            </arguments>
                        </configuration>
                    </execution>
                    <execution>
                        <id>docker-build-verify-image</id>
                        <phase>pre-integration-test</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>docker</executable>
                            <arguments>
                                <argument>build</argument>
                                <argument>--file</argument>
                                <argument>${project.basedir}/container/Dockerfile</argument>
                                <argument>--load</argument>
                                <argument>--tag</argument>
                                <argument>${verify.container.image}</argument>
                                <argument>${project.basedir}</argument>
                            </arguments>
                        </configuration>
                    </execution>
                    <execution>
                        <id>docker-stop-stale-verify-environment</id>
                        <phase>pre-integration-test</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>bash</executable>
                            <environmentVariables>
                                <VERIFY_ENV_BACKEND>${verify.environment.backend}</VERIFY_ENV_BACKEND>
                                <VERIFY_COMPOSE_FILE>${verify.compose.file}</VERIFY_COMPOSE_FILE>
                                <VERIFY_COMPOSE_PROJECT>${verify.compose.project}</VERIFY_COMPOSE_PROJECT>
                                <VERIFY_CONTAINER_IMAGE>${verify.container.image}</VERIFY_CONTAINER_IMAGE>
                                <VERIFY_CONTAINER_PORT>${verify.container.port}</VERIFY_CONTAINER_PORT>
                                <VERIFY_DB_PORT>${verify.db.port}</VERIFY_DB_PORT>
                                <VERIFY_DB_NAME>${verify.db.name}</VERIFY_DB_NAME>
                                <VERIFY_DB_USERNAME>${env.VERIFY_DB_USERNAME}</VERIFY_DB_USERNAME>
                                <VERIFY_DB_PASSWORD>${env.VERIFY_DB_PASSWORD}</VERIFY_DB_PASSWORD>
                            </environmentVariables>
                            <arguments>
                                <argument>${verify.environment.script}</argument>
                                <argument>down</argument>
                            </arguments>
                        </configuration>
                    </execution>
                    <execution>
                        <id>docker-run-verify-environment</id>
                        <phase>pre-integration-test</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>bash</executable>
                            <environmentVariables>
                                <VERIFY_ENV_BACKEND>${verify.environment.backend}</VERIFY_ENV_BACKEND>
                                <VERIFY_COMPOSE_FILE>${verify.compose.file}</VERIFY_COMPOSE_FILE>
                                <VERIFY_COMPOSE_PROJECT>${verify.compose.project}</VERIFY_COMPOSE_PROJECT>
                                <VERIFY_CONTAINER_IMAGE>${verify.container.image}</VERIFY_CONTAINER_IMAGE>
                                <VERIFY_CONTAINER_PORT>${verify.container.port}</VERIFY_CONTAINER_PORT>
                                <VERIFY_DB_PORT>${verify.db.port}</VERIFY_DB_PORT>
                                <VERIFY_DB_NAME>${verify.db.name}</VERIFY_DB_NAME>
                                <VERIFY_DB_USERNAME>${env.VERIFY_DB_USERNAME}</VERIFY_DB_USERNAME>
                                <VERIFY_DB_PASSWORD>${env.VERIFY_DB_PASSWORD}</VERIFY_DB_PASSWORD>
                            </environmentVariables>
                            <arguments>
                                <argument>${verify.environment.script}</argument>
                                <argument>up</argument>
                            </arguments>
                        </configuration>
                    </execution>
                    <execution>
                        <id>docker-wait-verify-container</id>
                        <phase>pre-integration-test</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>bash</executable>
                            <environmentVariables>
                                <VERIFY_ENV_BACKEND>${verify.environment.backend}</VERIFY_ENV_BACKEND>
                                <VERIFY_COMPOSE_FILE>${verify.compose.file}</VERIFY_COMPOSE_FILE>
                                <VERIFY_COMPOSE_PROJECT>${verify.compose.project}</VERIFY_COMPOSE_PROJECT>
                                <VERIFY_CONTAINER_IMAGE>${verify.container.image}</VERIFY_CONTAINER_IMAGE>
                                <VERIFY_CONTAINER_PORT>${verify.container.port}</VERIFY_CONTAINER_PORT>
                                <VERIFY_DB_PORT>${verify.db.port}</VERIFY_DB_PORT>
                                <VERIFY_DB_NAME>${verify.db.name}</VERIFY_DB_NAME>
                                <VERIFY_DB_USERNAME>${env.VERIFY_DB_USERNAME}</VERIFY_DB_USERNAME>
                                <VERIFY_DB_PASSWORD>${env.VERIFY_DB_PASSWORD}</VERIFY_DB_PASSWORD>
                            </environmentVariables>
                            <arguments>
                                <argument>${verify.environment.script}</argument>
                                <argument>wait</argument>
                            </arguments>
                        </configuration>
                    </execution>
                    <execution>
                        <id>docker-stop-verify-environment</id>
                        <phase>post-integration-test</phase>
                        <goals>
                            <goal>exec</goal>
                        </goals>
                        <configuration>
                            <executable>bash</executable>
                            <environmentVariables>
                                <VERIFY_ENV_BACKEND>${verify.environment.backend}</VERIFY_ENV_BACKEND>
                                <VERIFY_COMPOSE_FILE>${verify.compose.file}</VERIFY_COMPOSE_FILE>
                                <VERIFY_COMPOSE_PROJECT>${verify.compose.project}</VERIFY_COMPOSE_PROJECT>
                                <VERIFY_CONTAINER_IMAGE>${verify.container.image}</VERIFY_CONTAINER_IMAGE>
                                <VERIFY_CONTAINER_PORT>${verify.container.port}</VERIFY_CONTAINER_PORT>
                                <VERIFY_DB_PORT>${verify.db.port}</VERIFY_DB_PORT>
                                <VERIFY_DB_NAME>${verify.db.name}</VERIFY_DB_NAME>
                                <VERIFY_DB_USERNAME>${env.VERIFY_DB_USERNAME}</VERIFY_DB_USERNAME>
                                <VERIFY_DB_PASSWORD>${env.VERIFY_DB_PASSWORD}</VERIFY_DB_PASSWORD>
                            </environmentVariables>
                            <arguments>
                                <argument>${verify.environment.script}</argument>
                                <argument>capture-and-down</argument>
                                <argument>${project.build.directory}</argument>
                            </arguments>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-enforcer-plugin</artifactId>
                <executions>
                    <execution>
                        <id>enforce-maven</id>
                        <goals>
                            <goal>enforce</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <requireMavenVersion>
                                    <version>${required.maven.version}</version>
                                    <message>Maven ${required.maven.version}+ is required. Use the Maven Wrapper or upgrade your Maven installation.</message>
                                </requireMavenVersion>
                                <requireJavaVersion>
                                    <version>${java.version}</version>
                                    <message>Java ${java.version}+ is required.</message>
                                </requireJavaVersion>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
