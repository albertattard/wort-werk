#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SECRETS_FILE="${HOME}/.oci/oci.secrets.env"
WORDS=(
  amber
  birch
  cedar
  comet
  coral
  ember
  fern
  flint
  hazel
  juniper
  maple
  meadow
  moss
  pebble
  pine
  river
  slate
  spruce
)

random_word() {
  printf '%s' "${WORDS[RANDOM % ${#WORDS[@]}]}"
}

ensure_verify_credentials() {
  local generated=false

  if [[ -z "${VERIFY_DB_USERNAME:-}" ]]; then
    export VERIFY_DB_USERNAME
    VERIFY_DB_USERNAME="$(random_word)"
    generated=true
  fi

  if [[ -z "${VERIFY_DB_PASSWORD:-}" ]]; then
    export VERIFY_DB_PASSWORD
    VERIFY_DB_PASSWORD="$(random_word)"
    generated=true
  fi

  if [[ "${generated}" == "true" ]]; then
    echo "VERIFY_DB_USERNAME and/or VERIFY_DB_PASSWORD were not set; generated ephemeral rollout verify credentials." >&2
  fi
}

if [[ ! -f "${SECRETS_FILE}" ]]; then
  echo "Missing secrets file: ${SECRETS_FILE}" >&2
  echo "Create it first (for example with OCI_USERNAME and OCI_AUTH_TOKEN)." >&2
  exit 1
fi

# shellcheck source=/dev/null
source "${SECRETS_FILE}"
ensure_verify_credentials

exec "${REPO_ROOT}/infrastructure/oci/deploy.sh" rollout
